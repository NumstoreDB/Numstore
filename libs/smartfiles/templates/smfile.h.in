// Data Type Sizes

typedef uint@TSIZE_BITS@_t t_size; // Represents the size of a single type in bytes
typedef int@TSIZE_BITS@_t st_size; // Signed t_size
typedef uint@PSIZE_BITS@_t p_size; // To index inside a page
typedef int@PSIZE_BITS@_t sp_size; // Signed p_size
typedef uint@BSIZE_BITS@_t b_size; // Bytes size to index into a contiguous rope bytes
typedef int@BSIZE_BITS@_t sb_size; // Signed b_size
typedef uint@PGNO_BITS@_t pgno;   // Page number
typedef int@PGNO_BITS@_t spgno;   // Signed page number
typedef uint@TXID_BITS@_t txid;   // Transaction id
typedef int@TXID_BITS@_t stxid;   // Signed transaction id
typedef int@LSN_BITS@_t slsn;    // Wall index (often called LSN)
typedef uint@LSN_BITS@_t lsn;    // Wall index (often called LSN)
typedef uint@PGH_BITS@_t pgh;     // Page header
typedef uint@WLH_BITS@_t wlh;     // WAL header

#define PGNO_NULL U@PGNO_BITS@_MAX
#define LSN_NULL  U@LSN_BITS@_MAX
#define WLH_NULL  U@WLH_BITS@_MAX

#define PRt_size  PRIu@TSIZE_BITS@
#define PRst_size PRId@TSIZE_BITS@
