--tool=memcheck
--leak-check=full
--leak-resolution=high
--show-leak-kinds=all
--show-reachable=yes
--errors-for-leak-kinds=all
--track-origins=yes
--undef-value-errors=yes
--partial-loads-ok=no
--expensive-definedness-checks=yes
--track-fds=yes
--show-mismatched-frees=yes
--num-callers=40
--error-exitcode=1
