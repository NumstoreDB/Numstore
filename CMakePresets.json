{
  "version": 3,
  "configurePresets": [
    {
      "name": "base",
      "hidden": true,
      "binaryDir": "${sourceDir}/build/${presetName}",
      "warnings": { "uninitialized": true }
    },

    {
      "name": "debug",
      "inherits": "base",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE":           "Debug",
        "CMAKE_CONFIGURATION_TYPES":  "Debug",
        "ENABLE_NDEBUG":              "OFF",
        "ENABLE_NTEST":               "OFF",
        "ENABLE_NLOG":                "OFF",
        "ENABLE_COVERAGE":            "OFF",
        "ENABLE_PORTABLE":            "OFF",
        "ENABLE_STRIP":               "OFF",
        "ENABLE_ASAN":                "ON",
        "BUILD_TOOLS":                "ON",
        "BUILD_PYTHON_BINDINGS":      "ON",
        "BUILD_SAMPLES":              "ON"
      }
    },

    {
      "name": "debug-valgrind",
      "inherits": "debug",
      "cacheVariables": { 
        "ENABLE_ASAN":     "OFF" ,
        "ENABLE_PORTABLE": "ON"
      }
    },

    {
      "name": "debug-coverage",
      "inherits": "debug",
      "cacheVariables": { 
        "ENABLE_COVERAGE": "ON",
        "ENABLE_ASAN": "OFF"
      }
    },

    {
      "name": "release",
      "hidden": true,
      "inherits": "base",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE":           "Release",
        "CMAKE_CONFIGURATION_TYPES":  "Release",
        "ENABLE_NDEBUG":              "ON",
        "ENABLE_NTEST":               "ON",
        "ENABLE_NLOG":                "ON",
        "ENABLE_PORTABLE":            "OFF",
        "ENABLE_STRIP":               "OFF",
        "ENABLE_ASAN":                "OFF",
        "ENABLE_COVERAGE":            "OFF",
        "BUILD_TOOLS":                "ON",
        "BUILD_PYTHON_BINDINGS":      "ON",
        "BUILD_SAMPLES":              "ON"
      }
    },

    {
      "name": "release-tests-asan",
      "inherits": "release",
      "cacheVariables": {
        "ENABLE_NTEST": "OFF",
        "ENABLE_NLOG":  "OFF",
        "ENABLE_ASAN":  "ON"
      }
    },

    {
      "name": "package-release",
      "inherits": "release",
      "cacheVariables": {
        "ENABLE_STRIP":               "ON",
        "ENABLE_PORTABLE":            "ON",
        "BUILD_TOOLS":                "OFF",
        "BUILD_PYTHON_BINDINGS":      "OFF",
        "BUILD_SAMPLES":              "OFF"
      }
    },

    {
      "name": "ninja",
      "inherits": "base",
      "generator": "Ninja Multi-Config",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON"
      }
    }
  ],
  "buildPresets": [
    { "name": "debug",              "configurePreset": "debug",              "configuration": "Debug"   },
    { "name": "debug-valgrind",     "configurePreset": "debug-valgrind",     "configuration": "Debug"   },
    { "name": "debug-coverage",     "configurePreset": "debug-coverage",     "configuration": "Debug"   },
    { "name": "release",            "configurePreset": "release",            "configuration": "Release" },
    { "name": "release-tests-asan", "configurePreset": "release-tests-asan", "configuration": "Release" },
    { "name": "package-release",    "configurePreset": "package-release",    "configuration": "Release" }
  ]
}
