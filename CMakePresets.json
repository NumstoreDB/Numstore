        "ENABLE_LOGGING":   "OFF",
        "ENABLE_ASAN":      "ON",
        "OPTIMIZE_CODE":    "ON",
        "ENABLE_COVERAGE":  "OFF",
        "BUILD_TOOLS":      "OFF",
        "BUILD_SAMPLES":    "OFF"
