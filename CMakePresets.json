        "ENABLE_LOGGING":   "OFF",
        "ENABLE_ASAN":      "OFF",
        "OPTIMIZE_CODE":    "ON",
        "ENABLE_COVERAGE":  "OFF",
        "BUILD_TOOLS":      "OFF",
        "BUILD_SAMPLES":    "OFF"
      }
    },
    {
      "name": "ci-coverage",
      "inherits": "base",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "ENABLE_PORTABLE":  "ON",
        "ENABLE_TESTS":     "ON",
        "ENABLE_LOGGING":   "OFF",
        "ENABLE_ASAN":      "OFF",
        "OPTIMIZE_CODE":    "OFF",
        "ENABLE_COVERAGE":  "ON",
        "BUILD_TOOLS":      "OFF",
        "BUILD_SAMPLES":    "OFF"
      }
