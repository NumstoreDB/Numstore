      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "ENABLE_PORTABLE":  "ON",
        "ENABLE_TESTS":     "ON",
        "ENABLE_LOGGING":   "OFF",
        "ENABLE_ASAN":      "OFF",
        "OPTIMIZE_CODE":    "ON",
        "ENABLE_COVERAGE":  "OFF",
        "BUILD_TOOLS":      "ON",
        "BUILD_SAMPLES":    "ON"
      }
    },
    {
      "name": "ci-tests",
      "inherits": "base",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "ENABLE_PORTABLE":  "ON",
