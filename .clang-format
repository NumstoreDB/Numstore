# Base style rules
BasedOnStyle: Google
ColumnLimit: 100
IndentWidth: 2
ContinuationIndentWidth: 4
UseTab: Never

# Function parameters & arguments layout
AlignAfterOpenBracket: BlockIndent                  # Wrap long arguments onto new lines, indented as a block
BinPackParameters: false                            # Put each wrapped parameter on its own line
BinPackArguments: false                             # Put each wrapped argument on its own line
AllowAllParametersOfDeclarationOnNextLine: false   # Prevent dumping all parameters onto a single next line
AllowAllArgumentsOnNextLine: false                  # Prevent dumping all arguments onto a single next line

# Break return type on definitions, keep on declarations
AlwaysBreakAfterReturnType: AllDefinitions          # Break return type to next line on definitions (older Clang)
BreakAfterReturnType: AllDefinitions                # Break return type to next line on definitions (Clang 19+)
PenaltyReturnTypeOnItsOwnLine: 1
SpaceBeforeParens: Always                           # Put a space before control statement parentheses
IndentWrappedFunctionNames: false

# Brace placement rules
BreakBeforeBraces: Custom
BraceWrapping:
  AfterCaseLabel: true                              # Brace after case label goes on next line
  AfterControlStatement: Always                     # Braces for if/else/switch/for/while go on next line
  AfterEnum: true                                   # Enum opening brace goes on next line
  AfterFunction: true                               # Function body opening brace goes on next line
  AfterStruct: true                                 # Struct opening brace goes on next line
  BeforeElse: true                                  # Formats as } \n else
  BeforeWhile: true                                 # Formats as } \n while
  SplitEmptyFunction: false                         # Keep empty functions compact
  SplitEmptyRecord: false                           # Keep empty structs/classes compact
  SplitEmptyNamespace: false                        # Keep empty namespaces compact

# Inline short code blocks
AllowShortFunctionsOnASingleLine: None              # Never squeeze functions onto one line
AllowShortBlocksOnASingleLine: Always               # Allow single-line short blocks
AllowShortIfStatementsOnASingleLine: AllIfsAndElse # Allow one-line simple if/else statements
AllowShortLoopsOnASingleLine: true                 # Allow one-line simple loops
AllowShortCaseLabelsOnASingleLine: true             # Allow one-line simple case labels
AllowShortEnumsOnASingleLine: true                  # Allow one-line simple enums

# Auto-insert braces for control statements
InsertBraces: true                                  # Add missing braces to single-line if/else/for/while

# Preprocessor directives indentation
IndentPPDirectives: AfterHash                       # Indent nested macros after the '#' symbol
PPIndentWidth: 2                                    # Indentation spacing for nested macros

# Include files organization
SortIncludes: CaseSensitive
IncludeBlocks: Regroup                               # Group and sort includes dynamically
IncludeIsMainRegex: '([-_](test|unittest))?$'       # Identifies test files to pair with main headers
IncludeCategories:
  - Regex: '^"'                                     # Group 1: Local headers
    Priority: 1
  - Regex: '^<sys/'                                 # Group 2: POSIX system headers
    Priority: 2
  - Regex: '^<.*\.h>'                               # Group 3: C standard headers
    Priority: 3
  - Regex: '^<Python\.h>|numpy'                     # Group 4: Python headers
    Priority: 4
  - Regex: '^<.*>'                                  # Group 5: C++ standard & all other headers
    Priority: 5

# Whitespace cleanup
MaxEmptyLinesToKeep: 1                              # Never allow more than one consecutive empty line
KeepEmptyLinesAtTheStartOfBlocks: false            # Remove empty lines right after an opening brace
SpacesInParentheses: false
SpacesInSquareBrackets: false
SpacesInCStyleCastParentheses: false
SpaceAfterCStyleCast: false
SpaceBeforeAssignmentOperators: true                # Put spaces around '=' signs
SpacesBeforeTrailingComments: 1                    # One space before an inline comment
DerivePointerAlignment: false                       # Force fixed pointer layout
PointerAlignment: Right                             # Bind pointer asterisk to the variable name (e.g., int *var)
Cpp11BracedListStyle: true                          # Use modern C++ initialization spacing

# Consecutive block alignment
AlignConsecutiveMacros: Consecutive                # Vertically align backslashes/values in adjacent macros
AlignConsecutiveAssignments: Consecutive           # Vertically align '=' signs in adjacent lines
AlignConsecutiveDeclarations: Consecutive          # Vertically align variable names in adjacent declarations
AlignConsecutiveBitFields: Consecutive             # Vertically align bitfield colons
AlignTrailingComments: true                         # Vertically align inline comments on adjacent lines
AlignEscapedNewlines: Left                          # Align macro line-break backslashes to the left
AlignOperands: Align                                # Align operands when expressions wrap lines

# Line wraps inside expressions
BreakBeforeBinaryOperators: NonAssignment           # Wrap lines before operators (except assignment)
BreakStringLiterals: true                           # Automatically split long string literals across lines
ReflowComments: true                                # Automatically wrap long comments to stay under column limit
