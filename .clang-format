BasedOnStyle: Google

ColumnLimit: 100
IndentWidth: 2
ContinuationIndentWidth: 4
UseTab: Never

# ---------------------------------------------------------------------------
# Function signatures: Break return type on definitions, but keep them on 
# a single line for forward declarations. Wrap parameters if too long.
# ---------------------------------------------------------------------------
# BlockIndent breaks long parameters across lines naturally and places the 
# closing paren on its own line, preventing giant un-wrapped nested blocks.
AlignAfterOpenBracket: BlockIndent
BinPackParameters: false
BinPackArguments: false
AllowAllParametersOfDeclarationOnNextLine: false
AllowAllArgumentsOnNextLine: false

# Forces the return type down ONLY on definitions (implementations)
# AllDefinitions ensures function names remain at column 0 without wrapping indents
AlwaysBreakAfterReturnType: AllDefinitions   # Older clang-format versions
BreakAfterReturnType: AllDefinitions         # Clang-format 19+ 
PenaltyReturnTypeOnItsOwnLine: 1
SpaceBeforeParens: Always

IndentWrappedFunctionNames: false

# ---------------------------------------------------------------------------
# Braces: GNU/Custom style logic. Put braces on the next line when multi-line, 
# but allow short inline structures to stay compact if they fit.
# ---------------------------------------------------------------------------
BreakBeforeBraces: Custom
BraceWrapping:
  AfterCaseLabel: true
  AfterControlStatement: Always  # Forces 'if', 'else', 'switch', 'for', 'while' braces to next line
  AfterEnum: true
  AfterFunction: true            # Forces function implementation braces to next line
  AfterStruct: true
  BeforeElse: true               # Formats as } \n else instead of } else
  BeforeWhile: true              # Formats as } \n while instead of } while
  SplitEmptyFunction: false
  SplitEmptyRecord: false
  SplitEmptyNamespace: false

AllowShortFunctionsOnASingleLine: None
AllowShortBlocksOnASingleLine: Always
AllowShortIfStatementsOnASingleLine: AllIfsAndElse
AllowShortLoopsOnASingleLine: true
AllowShortCaseLabelsOnASingleLine: true
AllowShortEnumsOnASingleLine: true

# ---------------------------------------------------------------------------
# Always brace control statements. Single-statement if/else/for/while/do all
# get { } inserted. Switches already require braces around the body, so they
# are unaffected; case labels are governed by AllowShortCaseLabels above.
# Requires clang-format 15+. Do NOT also set RemoveBracesLLVM.
# ---------------------------------------------------------------------------
#InsertBraces: true

# ---------------------------------------------------------------------------
# Preprocessor: indent the body of nested #if / #ifdef / #ifndef blocks.
# "AfterHash" keeps the # in column 0 and indents what follows it:
#   #if FOO
#   #  if BAR
#   #     define BAZ 1
#   #  endif
#   #endif
# Use "BeforeHash" instead if you prefer the whole directive indented.
# ---------------------------------------------------------------------------
IndentPPDirectives: AfterHash
PPIndentWidth: 2

# ---------------------------------------------------------------------------
# Includes: sort, regroup into categories, and float the "main" header
# (foo.h in foo.c) to the very top. IncludeIsMainRegex's default already
# matches the source file's basename plus optional -test/_test/-unittest
# suffixes; tighten the regex below if you want exact-match only.
# ---------------------------------------------------------------------------
SortIncludes: CaseSensitive
IncludeBlocks: Regroup
IncludeIsMainRegex: '([-_](test|unittest))?$'
IncludeCategories:
  - Regex:    '^"'              # local "..." headers
    Priority: 1
  - Regex:    '^<sys/'          # POSIX system headers
    Priority: 2
  - Regex:    '^<.*\.h>'        # C standard headers (<stdio.h>, ...)
    Priority: 3
  - Regex:    '^<Python\.h>|numpy' # Python ecosystem headers
    Priority: 4
  - Regex:    '^<.*>'           # everything else in angle brackets (C++ libs, etc.)
    Priority: 5

InsertBraces: true

# ---------------------------------------------------------------------------
# Whitespace cleanup
# ---------------------------------------------------------------------------
MaxEmptyLinesToKeep: 1
KeepEmptyLinesAtTheStartOfBlocks: false
SpacesInParentheses: false
SpacesInSquareBrackets: false
SpacesInCStyleCastParentheses: false
SpaceAfterCStyleCast: false
SpaceBeforeAssignmentOperators: true
SpacesBeforeTrailingComments: 1
DerivePointerAlignment: false
PointerAlignment: Right             
Cpp11BracedListStyle: true

# ---------------------------------------------------------------------------
# Alignment of repetitive constructs
# ---------------------------------------------------------------------------
AlignConsecutiveMacros: Consecutive
AlignConsecutiveAssignments: Consecutive
AlignConsecutiveDeclarations: Consecutive
AlignConsecutiveBitFields: Consecutive
AlignTrailingComments: true
AlignEscapedNewlines: Left
AlignOperands: Align

# ---------------------------------------------------------------------------
# Line breaks within expressions and comments
# ---------------------------------------------------------------------------
BreakBeforeBinaryOperators: NonAssignment
BreakStringLiterals: true
ReflowComments: true
